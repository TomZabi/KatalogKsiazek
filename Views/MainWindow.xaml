<Window x:Class="KatalogKsiazek.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:KatalogKsiazek.ViewModels"
        Title="Katalog książek (MVVM)"
        Height="640" Width="1100"
        MinHeight="500" MinWidth="800"
        FontSize="13">

    <Window.Resources>
        <Style x:Key="BladStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Red"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Text}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="16">

            <!-- RESPONSYWNE KOLUMNY -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*" MinWidth="260"/>
            </Grid.ColumnDefinitions>

            <!-- LISTA KSIĄŻEK -->
            <GroupBox Header="Lista książek" Grid.Column="0">
                <DockPanel LastChildFill="True">

                    <!-- WYSZUKIWANIE -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding Filtr, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,4,0"
                                 ToolTip="Szukaj po tytule, autorze, gatunku lub stanie"/>
                        <Button Grid.Column="1"
                                Content="✕"
                                Command="{Binding CzyscWyszukiwanieCommand}"
                                Padding="6,2"
                                ToolTip="Wyczyść wyszukiwanie"/>
                    </Grid>

                    <ListBox ItemsSource="{Binding Ksiazki}"
                             SelectedItem="{Binding Wybrana, Mode=TwoWay}"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             BorderThickness="0">

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Expander Margin="0,2"
                                      HorizontalAlignment="Stretch">

                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Tytul}"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   MinWidth="150"/>
                                        <TextBlock Text=" — " Foreground="Gray"/>
                                        <TextBlock Text="{Binding Autor}"
                                                   Foreground="#555"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Expander.Header>

                                <Border Background="#F5F5F5"
                                        BorderBrush="#DDD"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="12,8"
                                        Margin="20,4,4,4">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Text="Rok:" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                   Text="{Binding Rok}"/>

                                        <TextBlock Grid.Row="0" Grid.Column="2"
                                                   Text="Gatunek:" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Row="0" Grid.Column="3"
                                                   Text="{Binding Gatunek}"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                   Text="Stan:" FontWeight="SemiBold"
                                                   Margin="0,6,0,0"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1"
                                                   Text="{Binding StanOpis}"
                                                   Margin="0,6,0,0"/>

                                        <TextBlock Grid.Row="1" Grid.Column="2"
                                                   Text="Ocena:" FontWeight="SemiBold"
                                                   Margin="0,6,0,0"/>
                                        <TextBlock Grid.Row="1" Grid.Column="3"
                                                   Text="{Binding OcenaOpis}"
                                                   Margin="0,6,0,0"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0"
                                                   Text="Uwagi:" FontWeight="SemiBold"
                                                   Margin="0,6,0,0"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1"
                                                   Grid.ColumnSpan="3"
                                                   Text="{Binding Uwagi}"
                                                   TextWrapping="Wrap"
                                                   Foreground="#444"
                                                   Margin="0,6,0,0"/>
                                    </Grid>

                                </Border>
                            </Expander>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    </ListBox>
                </DockPanel>
            </GroupBox>

            <!-- SPLITTER -->
            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#CCC"
                          ShowsPreview="True"/>

            <!-- SZCZEGÓŁY -->
            <GroupBox Header="Szczegóły książki" Grid.Column="2">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">

                        <TextBlock Text="Tytuł" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding Tytul, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,2,0,2"/>
                        <TextBlock Text="{Binding BladTytul}" Style="{StaticResource BladStyle}"/>

                        <TextBlock Text="Autor" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding Autor, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,2,0,2"/>
                        <TextBlock Text="{Binding BladAutor}" Style="{StaticResource BladStyle}"/>

                        <TextBlock Text="Rok" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding RokText, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,2,0,2"/>
                        <TextBlock Text="{Binding BladRok}" Style="{StaticResource BladStyle}"/>

                        <TextBlock Text="Gatunek" FontWeight="SemiBold"/>
                        <ComboBox ItemsSource="{Binding Gatunki}"
                                  SelectedItem="{Binding Gatunek}"
                                  IsEditable="True"
                                  Margin="0,2,0,2"/>
                        <TextBlock Text="{Binding BladGatunek}" Style="{StaticResource BladStyle}"/>

                        <TextBlock Text="Stan" FontWeight="SemiBold"/>
                        <StackPanel Margin="0,4,0,8">
                            <RadioButton Content="📚 Nowa"
                                         IsChecked="{Binding StanNowa}"
                                         GroupName="Stan" Margin="0,2"/>
                            <RadioButton Content="📖 W trakcie"
                                         IsChecked="{Binding StanWTrakcie}"
                                         GroupName="Stan" Margin="0,2"/>
                            <RadioButton Content="✅ Przeczytana"
                                         IsChecked="{Binding StanPrzeczytana}"
                                         GroupName="Stan" Margin="0,2"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                            <TextBlock Text="Ocena: " FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding OcenaOpis}"/>
                        </StackPanel>

                        <Slider Minimum="1" Maximum="10"
                                Value="{Binding Ocena}"
                                IsSnapToTickEnabled="True"
                                TickFrequency="1"
                                TickPlacement="BottomRight"
                                Margin="0,4,0,2"/>

                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="1" Foreground="Gray" FontSize="11"
                                       HorizontalAlignment="Left"/>
                            <TextBlock Text="10" Foreground="Gray" FontSize="11"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <TextBlock Text="Uwagi" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding Uwagi, UpdateSourceTrigger=PropertyChanged}"
                                 Height="60"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Margin="0,2,0,16"/>

                        <Button Content="➕ Dodaj książkę"
                                Command="{Binding DodajCommand}"
                                Padding="6"
                                Margin="0,0,0,6"/>

                        <Button Content="✏️ Zapisz zmiany"
                                Command="{Binding EdytujCommand}"
                                Padding="6"
                                Margin="0,0,0,6"/>

                        <Button Content="🗑️ Usuń książkę"
                                Command="{Binding UsunCommand}"
                                Padding="6"/>

                    </StackPanel>
                </ScrollViewer>
            </GroupBox>

    </Grid>
</Window>